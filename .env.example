# ------------------------------
# Backend (Spring Boot)
# ------------------------------
# Use local MongoDB for development or replace with your Atlas URI.
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smart_campus

# Generate a long random secret (at least 32 chars).
APP_AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
APP_AUTH_JWT_EXPIRATION_MINUTES=1440

# Google OAuth credentials from Google Cloud Console.
APP_AUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APP_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional: comma-separated list for multiple frontend client IDs.
APP_AUTH_GOOGLE_ALLOWED_AUDIENCES=

# ------------------------------
# Frontend (Vite)
# ------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceId\": \"{{assetId}}\",\n  \"resourceName\": \"{{assetName}}\",\n  \"startTime\": \"2026-04-16T13:00:00\",\n  \"endTime\": \"2026-04-16T14:00:00\",\n  \"purpose\": \"Mock rejection path test\",\n  \"expectedAttendees\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings"
              ]
            }
          }

                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('cancelBookingId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",

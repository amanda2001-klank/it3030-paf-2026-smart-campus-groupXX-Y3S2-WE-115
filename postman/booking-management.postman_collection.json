{
  "info": {
    "_postman_id": "7c7033fe-0d57-4ab4-9ab2-8dbe2d00f3b7",
    "name": "Smart Campus - Booking Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Booking backend requests for create, review, approval, rejection, cancellation, and retrieval."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "student-001"
    },
    {
      "key": "userName",
      "value": "Sample Student"
    },
    {
      "key": "assetId",
      "value": ""
    },
    {
      "key": "assetName",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    },
    {
      "key": "rejectBookingId",
      "value": ""
    },
    {
      "key": "cancelBookingId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Booking Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Prerequisite Asset",
      "item": [
        {
          "name": "Pick First Asset From Catalogue",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.content && data.content.length > 0) {",
                  "    pm.collectionVariables.set('assetId', data.content[0].id);",
                  "    pm.collectionVariables.set('assetName', data.content[0].assetName || '');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/catalog/assets/all?page=0&size=1&sortBy=createdAt&sortDir=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "catalog",
                "assets",
                "all"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "1"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortDir",
                  "value": "desc"
                }
              ]
            },
            "description": "Run this first so the booking requests use a real asset ObjectId."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('bookingId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              },
              {
                "key": "X-User-Name",
                "value": "{{userName}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceId\": \"{{assetId}}\",\n  \"resourceName\": \"{{assetName}}\",\n  \"startTime\": \"2026-04-15T09:00:00\",\n  \"endTime\": \"2026-04-15T11:00:00\",\n  \"purpose\": \"Student project presentation\",\n  \"expectedAttendees\": 40\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings"
              ]
            }
          }
        },
        {
          "name": "Create Booking For Rejection Flow",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
